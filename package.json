{
  "name": "highwin-next",
  "version": "2.0.0",
  "description": "红楹金融终端 - 深圳希施玛数据科技有限公司",
  "main": "./out/main/index.js",
  "author": "CSMAR",
  "homepage": "https://www.csmar.com",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "generate-routes": "tsr generate",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:win:dev": "set NODE_ENV=development&& npm run build && electron-builder --win",
    "build:portable": "npm run build && electron-builder --win portable",
    "build:portable:dev": "set NODE_ENV=development&& npm run build && electron-builder --win portable",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@microsoft/signalr": "^9.0.6",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.9",
    "@radix-ui/react-context-menu": "^2.2.14",
    "@radix-ui/react-dialog": "^1.1.13",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-progress": "^1.1.6",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-select": "^2.2.4",
    "@radix-ui/react-separator": "^1.1.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.11",
    "@radix-ui/react-toggle": "^1.1.8",
    "@tanstack/react-query": "^5.81.2",
    "@tanstack/react-table": "^8.21.3",
    "big.js": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.1",
    "electron-updater": "^6.1.7",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "ky": "^1.8.2",
    "lightweight-charts": "^5.0.6",
    "lucide-react": "^0.535.0",
    "nanoid": "^5.1.5",
    "next-themes": "^0.4.6",
    "react-resizable-panels": "^3.0.2",
    "react-select": "^5.10.1",
    "sonner": "^2.0.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/postcss": "^4.1.7",
    "@tanstack/react-router": "^1.121.34",
    "@tanstack/router-cli": "^1.129.8",
    "@tanstack/router-devtools": "^1.121.34",
    "@tanstack/router-vite-plugin": "^1.121.34",
    "@types/big.js": "^6.2.2",
    "@types/lodash": "^4.17.19",
    "@types/node": "^24.0.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.8.1",
    "electron-store": "^10.0.1",
    "electron-vite": "^4.0.0",
    "eslint": "^9.29.0",
    "eslint-plugin-react": "^7.34.3",
    "immer": "^10.1.1",
    "lodash": "^4.17.21",
    "motion": "^12.12.1",
    "postcss": "^8.5.1",
    "prettier": "^3.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.7",
    "tw-animate-css": "^1.2.9",
    "typescript": "^5.9.2",
    "vite": "^7.0.6",
    "zustand": "^5.0.4"
  }
}
